# ========================================
# 电商后端环境配置模板
# 复制此文件为 .env 并填写实际值
# ========================================

# 应用配置
APP_NAME=电商平台 API
APP_VERSION=1.0.0
DEBUG=false

# 数据库（生产环境建议用 PostgreSQL）
DATABASE_URL=sqlite:///./ecommerce.db
# DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce

# JWT 密钥（上线前务必修改！）
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 微信小程序配置
WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here

# 微信支付配置
WECHAT_MCH_ID=your_merchant_id
WECHAT_API_KEY=your_api_key
WECHAT_NOTIFY_URL=https://api.your-domain.com/api/payments/notify

# 公众号/订阅号通知配置
WECHAT_OFFICIAL_APPID=your_official_appid
WECHAT_OFFICIAL_SECRET=your_official_secret
WECHAT_ORDER_TEMPLATE_ID=your_template_id
WECHAT_MERCHANT_OPENID=your_openid

# 微信支付 V3 配置
WECHAT_PAY_MERCHANT_SERIAL_NO=your_serial_no
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_PAY_CERT_PATH=./certs/apiclient_cert.pem
WECHAT_PAY_PLATFORM_CERT_PATH=./certs/platform_cert.pem

# CORS 配置（生产环境只允许你的域名）
CORS_ORIGINS=["https://api.your-domain.com"]

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO