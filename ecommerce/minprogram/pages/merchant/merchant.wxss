/* pages/merchant/merchant.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #0f172a;
}

.subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 26rpx;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.search-card {
  padding: 20rpx;
}

.search-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 28rpx;
}

.search-btn,
.clear-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
}

.search-btn {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
}

.clear-btn {
  background: #f8fafc;
  color: #475569;
  border: 1rpx solid #e2e8f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #0f172a;
}

.input-group {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.input,
.textarea,
.picker {
  width: 100%;
  min-height: 72rpx;
  box-sizing: border-box;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  padding: 0 20rpx;
  background: #f8fafc;
  font-size: 28rpx;
}

.textarea {
  padding: 16rpx 20rpx;
  min-height: 160rpx;
}

.image-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.image-input {
  flex: 1;
}

.upload-btn {
  flex-shrink: 0;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.image-preview {
  width: 100%;
  height: 320rpx;
  margin-top: 16rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.filter-item {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 26rpx;
  border: 1rpx solid #e2e8f0;
}

.filter-item.active {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
  border-color: transparent;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 10rpx;
}

.reset-btn,
.submit-btn,
.back-btn,
.delete-btn,
.edit-btn {
  border-radius: 999rpx;
  font-size: 26rpx;
}

.reset-btn {
  flex: 1;
  background: #f8fafc;
  color: #475569;
  border: 1rpx solid #e2e8f0;
}

.submit-btn {
  flex: 2;
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
  color: #fff;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.product-main {
  flex: 1;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.product-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}

.product-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.edit-btn {
  background: #eff6ff;
  color: #2563eb;
  min-width: 108rpx;
}

.delete-btn {
  background: #fff1f2;
  color: #e11d48;
  min-width: 108rpx;
}

.empty-state {
  text-align: center;
  padding: 56rpx 0;
  color: #94a3b8;
}

.empty-state-icon {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.empty-state-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.empty-state-desc {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.back-btn {
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
  color: #0f172a;
  border: 1rpx solid #e2e8f0;
}

.footer-actions {
  padding: 12rpx 0 24rpx;
}

.back-btn {
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
  color: #0f172a;
  border: 1rpx solid #e2e8f0;
}
