/* pages/merchant/merchant.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #0f172a;
}

.subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 26rpx;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.action-card {
  padding: 20rpx;
}

.announcement-manage-btn {
  width: 100%;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.settings-card {
  border-color: #bfdbfe;
}

.settings-tip {
  margin-top: 8rpx;
  color: #94a3b8;
  font-size: 22rpx;
  line-height: 1.6;
}

.settings-qrcode-preview {
  width: 220rpx;
  height: 220rpx;
  margin-top: 16rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.settings-save-btn {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.search-card {
  padding: 20rpx;
}

.search-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 28rpx;
}

.search-btn,
.clear-btn {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
}

.search-btn {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
}

.clear-btn {
  background: #f8fafc;
  color: #475569;
  border: 1rpx solid #e2e8f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #0f172a;
}

.input-group {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.input,
.textarea,
.picker {
  width: 100%;
  min-height: 72rpx;
  box-sizing: border-box;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  padding: 0 20rpx;
  background: #f8fafc;
  font-size: 28rpx;
}

.textarea {
  padding: 16rpx 20rpx;
  min-height: 160rpx;
}

.image-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.image-input {
  flex: 1;
}

.upload-btn {
  flex-shrink: 0;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.image-preview {
  width: 100%;
  height: 320rpx;
  margin-top: 16rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
}

.category-create-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 12rpx;
}

.category-input {
  flex: 1;
  min-width: 0;
}

.category-add-btn {
  flex-shrink: 0;
  width: 170rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 18rpx;
  padding: 0;
  background: linear-gradient(135deg, #16a34a 0%, #0f766e 100%);
  color: #fff;
  font-size: 24rpx;
}

.category-picker {
  line-height: 72rpx;
  color: #334155;
}

.category-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.category-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 8rpx 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.category-tag.active {
  background: #eff6ff;
  border-color: #93c5fd;
}

.category-tag-name {
  color: #334155;
  font-size: 24rpx;
}

.category-delete-btn {
  width: 84rpx;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #fff1f2;
  color: #e11d48;
  border: 1rpx solid #fecdd3;
  font-size: 20rpx;
}

.category-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.filter-item {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 26rpx;
  border: 1rpx solid #e2e8f0;
}

.filter-item.active {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
  border-color: transparent;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 10rpx;
}

.reset-btn,
.submit-btn,
.back-btn,
.delete-btn,
.edit-btn {
  border-radius: 999rpx;
  font-size: 26rpx;
}

.reset-btn {
  flex: 1;
  background: #f8fafc;
  color: #475569;
  border: 1rpx solid #e2e8f0;
}

.submit-btn {
  flex: 2;
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
  color: #fff;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.product-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.product-main {
  flex: 1;
  min-width: 0;
}

.product-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.product-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}

.product-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.edit-btn {
  background: #eff6ff;
  color: #2563eb;
  min-width: 108rpx;
}

.delete-btn {
  background: #fff1f2;
  color: #e11d48;
  min-width: 108rpx;
}

.empty-state {
  text-align: center;
  padding: 56rpx 0;
  color: #94a3b8;
}

.empty-state-icon {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.empty-state-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.empty-state-desc {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.back-btn {
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
  color: #0f172a;
  border: 1rpx solid #e2e8f0;
}

.footer-actions {
  padding: 12rpx 0 24rpx;
}

.announcement-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(15, 23, 42, 0.62);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.announcement-dialog {
  width: 100%;
  max-width: 620rpx;
  border-radius: 28rpx;
  background: #ffffff;
  padding: 36rpx 32rpx 28rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 72rpx rgba(15, 23, 42, 0.28);
}

.announcement-editor-dialog .announcement-actions {
  display: flex;
  gap: 16rpx;
}

.announcement-editor-dialog .announcement-close-btn.secondary {
  background: #f8fafc;
  color: #475569;
  border: 1rpx solid #e2e8f0;
}

.announcement-editor-dialog .announcement-close-btn.primary {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff;
}

.announcement-header {
  margin-bottom: 20rpx;
}

.announcement-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.announcement-content {
  max-height: 420rpx;
  overflow-y: auto;
  font-size: 28rpx;
  line-height: 1.8;
  color: #334155;
  white-space: pre-wrap;
  word-break: break-word;
}

.announcement-textarea {
  min-height: 220rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
}

.order-section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.order-section-head .section-title {
  margin-bottom: 8rpx;
}

.sales-total {
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 800;
}

.clear-orders-btn {
  flex-shrink: 0;
  min-width: 160rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  background: #fff1f2;
  color: #e11d48;
  font-size: 24rpx;
  font-weight: 700;
  border: 1rpx solid #fecdd3;
}

.order-stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.order-stat-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.order-stat-card.stat-sales {
  grid-column: span 2;
  background: linear-gradient(135deg, #fff7ed 0%, #fef2f2 100%);
  border-color: #fed7aa;
}

.order-stat-value {
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.order-stat-label {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.stat-paid .order-stat-value {
  color: #f97316;
}

.stat-shipped .order-stat-value {
  color: #2563eb;
}

.stat-completed .order-stat-value {
  color: #16a34a;
}

.stat-sales .order-stat-value {
  color: #ef4444;
}

.order-filter-tabs {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  margin-bottom: 16rpx;
  padding-bottom: 4rpx;
}

.order-filter-tab {
  flex-shrink: 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 24rpx;
  border: 1rpx solid #e2e8f0;
}

.order-filter-tab.active {
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
  color: #fff;
  border-color: transparent;
  font-weight: 700;
}

.order-search-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 18rpx;
}

.order-search-input {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 24rpx;
}

.order-search-clear {
  flex-shrink: 0;
  width: 120rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  color: #475569;
  border: 1rpx solid #e2e8f0;
  font-size: 24rpx;
  padding: 0;
}


.order-item {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.order-main {
  flex: 1;
  min-width: 0;
}

.order-row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.order-no {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  word-break: break-all;
}

.order-status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #e2e8f0;
  color: #475569;
}

.order-status.paid {
  background: #fef3c7;
  color: #b45309;
}

.order-status.shipped {
  background: #dcfce7;
  color: #15803d;
}

.order-status.pending {
  background: #dbeafe;
  color: #1d4ed8;
}

.order-status.completed {
  background: #e0e7ff;
  color: #4338ca;
}

.order-status.cancelled {
  background: #fee2e2;
  color: #b91c1c;
}

.order-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #64748b;
}

.order-info-block {
  margin-top: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
}

.order-info-line {
  font-size: 24rpx;
  color: #334155;
  line-height: 1.6;
  word-break: break-all;
}

.info-label {
  color: #64748b;
  font-weight: 700;
}


.ship-btn {
  min-width: 160rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #16a34a 0%, #0f766e 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.shipped-badge {
  min-width: 160rpx;
  text-align: center;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  color: #15803d;
  font-size: 24rpx;
  font-weight: 700;
}

