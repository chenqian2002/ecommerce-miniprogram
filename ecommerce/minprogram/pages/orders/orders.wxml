<!--pages/orders/orders.wxml-->
<view class="container">
  <!-- 顶部导航 -->
  <view class="top-nav">
    <view class="nav-title">我的订单</view>
  </view>

  <!-- 订单标签 -->
  <view class="order-tabs">
    <view 
      class="tab-item {{orderStatus === 'all' ? 'active' : ''}}"
      bindtap="switchTab"
      data-status="all"
    >
      全部
    </view>
    <view 
      class="tab-item {{orderStatus === 'pending' ? 'active' : ''}}"
      bindtap="switchTab"
      data-status="pending"
    >
      待付款
    </view>
    <view 
      class="tab-item {{orderStatus === 'shipped' ? 'active' : ''}}"
      bindtap="switchTab"
      data-status="shipped"
    >
      已发货
    </view>
    <view 
      class="tab-item {{orderStatus === 'received' ? 'active' : ''}}"
      bindtap="switchTab"
      data-status="received"
    >
      已收货
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="content">
    <view wx:if="{{orders.length === 0}}" class="empty">
      <view class="empty-icon">📦</view>
      <text>暂无订单</text>
    </view>

    <view wx:else class="order-list">
      <view wx:for="{{orders}}" wx:key="id" class="order-card">
        <!-- 订单头部 -->
        <view class="order-header">
          <view class="order-no">订单号：{{item.order_no}}</view>
          <view class="order-status">{{item.status_text}}</view>
        </view>

        <!-- 订单商品 -->
        <view class="order-items">
          <view wx:for="{{item.items}}" wx:key="product_id" class="order-item">
            <view class="item-name">{{item.name}}</view>
            <view class="item-price">¥{{item.price}} × {{item.quantity}}</view>
          </view>
        </view>

        <!-- 订单底部 -->
        <view class="order-footer">
          <view class="order-total">共 {{item.total_items}} 件商品</view>
          <view class="amount">合计：<text class="price">¥{{item.total_amount}}</text></view>
        </view>

        <!-- 操作按钮 -->
        <view class="order-actions">
          <button class="action-btn" bindtap="detailOrder" data-order-id="{{item.id}}">
            查看详情
          </button>
          <button 
            wx:if="{{item.status === 'pending'}}" 
            class="action-btn pay-btn" 
            bindtap="payOrder" 
            data-order-id="{{item.id}}"
          >
            立即支付
          </button>
        </view>
      </view>
    </view>
  </view>
</view>
