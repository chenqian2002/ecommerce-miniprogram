<!--pages/orders/orders.wxml-->
<view class="container">
  <view class="top-nav">
    <view class="nav-title">我的订单</view>
    <view class="nav-subtitle">下单后可在这里查看支付、发货与收货状态</view>
  </view>

  <view class="order-tabs">
    <view class="tab-item {{orderStatus === 'all' ? 'active' : ''}}" bindtap="switchTab" data-status="all">全部</view>
    <view class="tab-item {{orderStatus === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-status="pending">待付款</view>
    <view class="tab-item {{orderStatus === 'paid' ? 'active' : ''}}" bindtap="switchTab" data-status="paid">待发货</view>
    <view class="tab-item {{orderStatus === 'shipped' ? 'active' : ''}}" bindtap="switchTab" data-status="shipped">已发货</view>
    <view class="tab-item {{orderStatus === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-status="completed">已完成</view>
  </view>

  <view class="content">
    <view wx:if="{{loading}}" class="loading-state">加载中...</view>

    <view wx:elif="{{orders.length === 0}}" class="empty">
      <view class="empty-icon">📦</view>
      <view class="empty-title">暂无订单</view>
      <view class="empty-desc">去商品页逛逛，选中商品后即可下单</view>
      <button class="empty-btn" bindtap="goToProducts">去逛逛</button>
    </view>

    <view wx:else class="order-list">
      <view wx:for="{{orders}}" wx:key="id" class="order-card">
        <view class="order-header">
          <view class="order-no">订单号：{{item.order_no}}</view>
          <view class="order-status status-{{item.status}}">{{item.status_text}}</view>
        </view>

        <view class="order-footer">
          <view class="order-total">共 {{item.total_items}} 件商品</view>
          <view class="amount">合计：<text class="price">¥{{item.total_amount}}</text></view>
        </view>

        <view class="order-actions">
          <button class="action-btn" bindtap="detailOrder" data-order-id="{{item.id}}">查看详情</button>
          <button wx:if="{{item.status === 'pending'}}" class="action-btn pay-btn" bindtap="payOrder" data-order-id="{{item.id}}">立即支付</button>
          <button wx:if="{{item.status === 'pending'}}" class="action-btn danger-btn" bindtap="cancelOrder" data-order-id="{{item.id}}">取消订单</button>
        </view>
      </view>
    </view>
  </view>
</view>

