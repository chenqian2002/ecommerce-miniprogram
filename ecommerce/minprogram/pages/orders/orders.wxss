
/* pages/orders/orders.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
}


.top-nav {
  padding: 24rpx 28rpx 20rpx;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 55%, #2563eb 100%);
  color: white;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.18);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
}

.nav-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
}

.order-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.96);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.9);
  overflow-x: auto;
  padding: 0 12rpx;
}

.tab-item {
  flex: 1;
  padding: 18rpx 16rpx;
  text-align: center;
  color: #64748b;
  font-size: 26rpx;
  min-width: 96rpx;
  white-space: nowrap;
  border-bottom: 3rpx solid transparent;
}

.tab-item.active {
  color: #2563eb;
  border-bottom-color: #2563eb;
  font-weight: 700;
}

.content {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx;
}

.loading-state,
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #94a3b8;
}

.empty-icon {
  font-size: 88rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #0f172a;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 24rpx;
}

.empty-btn {
  width: 240rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.order-no {
  font-size: 24rpx;
  color: #64748b;
  padding-right: 16rpx;
}

.order-status {
  font-size: 24rpx;
  font-weight: 700;
}

.status-pending { color: #ef4444; }
.status-paid { color: #f97316; }
.status-shipped { color: #2563eb; }
.status-completed { color: #16a34a; }
.status-cancelled { color: #64748b; }

.shipping-tip {
  padding: 16rpx 24rpx 0;
  font-size: 24rpx;
  color: #2563eb;
}

.service-note {
  margin: 16rpx 24rpx 0;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  color: #c2410c;
  font-size: 24rpx;
  line-height: 1.6;
}

.copy-service-btn {
  margin-top: 12rpx;
  width: 220rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
  color: #fff;
  font-size: 22rpx;
  padding: 0;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 24rpx 0;
}


  .order-total {
  font-size: 24rpx;
  color: #64748b;
}


.amount {
  font-size: 26rpx;
  color: #0f172a;
}

.price {
  color: #ef4444;
  font-weight: 800;
  font-size: 30rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  padding: 18rpx 24rpx 22rpx;
}

.action-btn {
  width: 160rpx;
  height: 64rpx;
  padding: 0;
  line-height: 64rpx;
  font-size: 24rpx;
  background-color: white;
  color: #2563eb;
  border: 1rpx solid #2563eb;
  border-radius: 999rpx;
  text-align: center;
}


.action-btn.danger-btn {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  border-color: transparent;
}

.action-btn.pay-btn {
  background: linear-gradient(135deg, #16a34a 0%, #059669 100%);
  color: #fff;
  border-color: transparent;
}


.footer-actions {
  padding: 12rpx 0 24rpx;
}

.back-btn {
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
  color: #0f172a;
  border: 1rpx solid #e2e8f0;
}

.action-btn.refund-btn {
  background: #fff7ed;
  color: #c2410c;
  border-color: #fed7aa;
}

/* 退款/售后弹窗 */
.refund-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(15, 23, 42, 0.62);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.refund-dialog {
  width: 100%;
  max-width: 620rpx;
  border-radius: 28rpx;
  background: #ffffff;
  padding: 36rpx 32rpx 28rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 72rpx rgba(15, 23, 42, 0.28);
}

.refund-header {
  margin-bottom: 20rpx;
}

.refund-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.refund-desc {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.refund-tip {
  font-size: 28rpx;
  color: #334155;
  margin-bottom: 8rpx;
}

.refund-wechat {
  font-weight: 700;
  color: #2563eb;
}

.refund-actions {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.refund-copy-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.refund-close-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 28rpx;
  font-weight: 500;
}




