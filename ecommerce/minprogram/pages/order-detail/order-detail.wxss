/* pages/order-detail/order-detail.wxss */
.page {
  padding: 24rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

.title {
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
  color: #0f172a;
}

.loading,
.empty {
  text-align: center;
  color: #94a3b8;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #0f172a;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #64748b;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #0f172a;
}

.row:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  color: #0f172a;
}

.address-name {
  font-weight: 700;
  margin-bottom: 8rpx;
  color: #0f172a;
}

.shipping-banner {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  color: #1d4ed8;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.shipping-desc {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.service-card {
  background: #fff7ed;
  border-color: #fed7aa;
}

.service-desc {
  color: #c2410c;
  font-size: 26rpx;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.service-wechat {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.service-qrcode {
  width: 260rpx;
  height: 260rpx;
  display: block;
  margin: 8rpx 0 18rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid #fed7aa;
}

.service-qrcode-tip {
  margin-bottom: 16rpx;
  color: #9a3412;
  font-size: 24rpx;
  line-height: 1.6;
}

.copy-service-btn {
  width: 240rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
  color: #fff;
  font-size: 24rpx;
  padding: 0;
}

.item-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.item-row:last-child {
  border-bottom: none;
}

.item-name {
  flex: 1;
  color: #0f172a;
  padding-right: 20rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  color: #fff;
  font-weight: 700;
  border: none;
}

.pay-btn {
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
}

.primary-btn {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
}

.action-btn.ghost-btn {
  background: rgba(255, 255, 255, 0.94);
  color: #0f172a;
  border: 1rpx solid #e2e8f0;
}

.footer-actions {
  padding: 12rpx 0 24rpx;
}

.back-btn {
  width: 100%;
  margin-top: 12rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #0f172a;
  border: 1rpx solid #e2e8f0;
}
