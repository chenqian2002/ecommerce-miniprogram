/* pages/product-detail/product-detail.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  box-sizing: border-box;
}

.loading,
.empty {
  text-align: center;
  color: #94a3b8;
  padding: 120rpx 0;
  font-size: 30rpx;
}

.banner {
  height: 420rpx;
  border-radius: 30rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.12);
}

.banner-item {
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 120rpx;
  background: linear-gradient(135deg, #e0e7ff 0%, #fce7f3 100%);
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.title {
  flex: 1;
  font-size: 38rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
}

.favorite-btn {
  flex-shrink: 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 24rpx;
}

.favorite-btn.active {
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
  color: #fff;
}

.price {
  color: #ef4444;
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.stock,
.desc,
.original-price {
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.7;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  color: #0f172a;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
  border-radius: 999rpx;
  color: #fff;
  font-weight: 700;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
}

.cart-btn {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
}

.buy-btn {
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
}
