/* pages/products/products.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
}

.top-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 28rpx 18rpx;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 55%, #2563eb 100%);
  color: #fff;
  font-weight: bold;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.18);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.nav-cart {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.search-bar {
  display: flex;
  gap: 14rpx;
  padding: 20rpx 24rpx 16rpx;
  background: transparent;
  align-items: center;
  flex-wrap: wrap;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.35);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.search-btn,
.clear-btn {
  min-width: 120rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 26rpx;
  border-radius: 22rpx;
  padding: 0 18rpx;
  border: none;
}

.search-btn {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.22);
}

.clear-btn {
  background: rgba(255, 255, 255, 0.92);
  color: #475569;
  border: 1rpx solid rgba(148, 163, 184, 0.35);
}

.sort-scroll,
.category-scroll {
  white-space: nowrap;
  background: transparent;
}

.sort-list,
.category-list {
  display: flex;
  gap: 14rpx;
  padding: 0 24rpx 16rpx;
}

.sort-item,
.category-item {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #64748b;
  font-size: 24rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.04);
}

.sort-item.active,
.category-item.active {
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
  font-weight: 600;
  border-color: transparent;
}

.banner {
  height: 240rpx;
  margin: 0 24rpx 18rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.12);
}

.banner-item {
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.banner-1 {
  background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);
}

.banner-2 {
  background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);
}

.banner-3 {
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
}

.content {
  flex: 1;
  padding: 0 24rpx 120rpx;
  overflow-y: auto;
}

.empty,
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 320rpx;
  color: #94a3b8;
  font-size: 30rpx;
  text-align: center;
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  align-content: start;
  padding-bottom: 20px;
}

.product-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.85);
}

.product-card:active {
  transform: scale(0.98);
}

.product-image {
  width: 100%;
  height: 220rpx;
  background: linear-gradient(135deg, #e0e7ff 0%, #fce7f3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.image-placeholder {
  font-size: 56rpx;
}

.product-info {
  padding: 18rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
}

.product-price {
  font-size: 32rpx;
  color: #ef4444;
  font-weight: 800;
}

.add-btn {
  min-width: 122rpx;
  height: 64rpx;
  padding: 0 16rpx;
  line-height: 64rpx;
  font-size: 22rpx;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
  border: none;
  border-radius: 18rpx;
  font-weight: 600;
}

.add-btn:active {
  opacity: 0.92;
}

.cart-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  height: 108rpx;
  background: rgba(15, 23, 42, 0.94);
  backdrop-filter: blur(16px);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx 0 16rpx;
  box-sizing: border-box;
  z-index: 20;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.22);
}

.cart-icon-wrap {
  position: relative;
  width: 92rpx;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cart-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}

.cart-badge {
  position: absolute;
  right: 0;
  top: 0;
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: #f43f5e;
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.cart-info {
  flex: 1;
  min-width: 0;
  color: #fff;
  margin-left: 14rpx;
}

.cart-price {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.1;
}

.cart-tip {
  font-size: 20rpx;
  color: rgba(226, 232, 240, 0.75);
  margin-top: 4rpx;
}

.checkout-btn {
  min-width: 190rpx;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #475569 0%, #1e293b 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 0 22rpx;
}

.checkout-btn.active {
  background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);
  color: #fff;
}



