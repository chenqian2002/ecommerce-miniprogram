<!--pages/products/products.wxml-->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="top-nav">
    <view class="nav-title">电商平台</view>
    <view class="nav-cart" bindtap="goToCart">
      <text>🛒</text>
    </view>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner" indicator-dots autoplay interval="5000" duration="1000">
    <swiper-item>
      <view class="banner-item banner-1">特价商品 限时优惠</view>
    </swiper-item>
    <swiper-item>
      <view class="banner-item banner-2">热销商品 好评如潮</view>
    </swiper-item>
    <swiper-item>
      <view class="banner-item banner-3">新品上市 立享优惠</view>
    </swiper-item>
  </swiper>

  <!-- 分类导航 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view class="category-item active">全部</view>
      <view class="category-item">热销</view>
      <view class="category-item">新品</view>
      <view class="category-item">优惠</view>
    </view>
  </scroll-view>

  <!-- 商品网格 -->
  <view class="content">
    <view wx:if="{{products.length === 0}}" class="empty">
      <text>暂无商品</text>
    </view>

    <view wx:else class="product-grid">
      <view wx:for="{{products}}" wx:key="id" class="product-card">
        <!-- 商品图片 -->
        <view class="product-image">
          <view class="image-placeholder">🍔</view>
        </view>
        
        <!-- 商品信息 -->
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-desc">{{item.description || '美味推荐'}}</view>
          
          <view class="product-footer">
            <view class="price-section">
              <view class="product-price">¥{{item.price}}</view>
            </view>
            <button class="add-btn" bindtap="handleAddToCart" data-product-id="{{item.id}}">
              加入购物车
            </button>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
