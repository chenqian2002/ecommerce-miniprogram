<!-- pages/products/products.wxml -->
<view class="container">
  <view class="top-nav">
    <view class="nav-title">购物平台</view>
    <view class="nav-cart" bindtap="goToCart">
      <text>🛒</text>
    </view>
  </view>

  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索商品名称"
      value="{{searchValue}}"
      bindinput="handleSearchInput"
      confirm-type="search"
      bindconfirm="handleSearch"
    />
    <button class="search-btn" bindtap="handleSearch">搜索</button>
    <button class="clear-btn" bindtap="clearSearch">重置</button>
  </view>

  <scroll-view class="sort-scroll" scroll-x>
    <view class="sort-list">
      <view
        wx:for="{{sortOptions}}"
        wx:key="value"
        class="sort-item {{sortBy === item.value ? 'active' : ''}}"
        bindtap="changeSort"
        data-sort="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <swiper class="banner" indicator-dots autoplay interval="5000" duration="1000">
    <swiper-item>
      <view class="banner-item banner-1">特价商品 限时优惠</view>
    </swiper-item>
    <swiper-item>
      <view class="banner-item banner-2">热销商品 好评如潮</view>
    </swiper-item>
    <swiper-item>
      <view class="banner-item banner-3">新品上市 立享优惠</view>
    </swiper-item>
  </swiper>

  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item {{currentCategoryId === item.id ? 'active' : ''}}"
        bindtap="selectCategory"
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view class="content">
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{products.length === 0}}" class="empty">
      <text>{{currentKeyword ? '没有找到相关商品' : '暂无商品'}}</text>
    </view>

    <view wx:else class="product-grid">
      <view
        wx:for="{{products}}"
        wx:key="id"
        class="product-card"
        bindtap="goToDetail"
        data-product-id="{{item.id}}"
      >
        <view class="product-image">
          <view class="image-placeholder">🍔</view>
        </view>
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-desc">{{item.description || '精选好物'}}</view>
          <view class="product-footer">
            <view class="product-price">¥{{item.price}}</view>
            <button class="add-btn" catchtap="handleAddToCart" data-product-id="{{item.id}}">加入购物车</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="cart-bar">
    <view class="cart-icon-wrap" bindtap="goToCart">
      <view class="cart-icon">🛒</view>
      <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
    </view>
    <view class="cart-info">
      <view class="cart-price">¥{{cartTotal}}</view>
      <view class="cart-tip">另需配送费￥3</view>
    </view>
    <button class="checkout-btn {{cartCount > 0 ? 'active' : ''}}" bindtap="handleCheckout">
      {{cartCount > 0 ? '去结算' : '￥20 起送'}}
    </button>
  </view>
</view>




