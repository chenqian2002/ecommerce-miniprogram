<!--pages/settings/settings.wxml-->
<view class="page">
  <view class="title">设置</view>

  <view class="card">
    <view class="row">
      <text>版本信息</text>
      <text>{{version}}</text>
    </view>
    <view class="row">
      <text>缓存状态</text>
      <text>{{cacheInfo}}</text>
    </view>
  </view>

  <view class="card">
    <view class="tip-title">温馨提示</view>
    <view class="tip-item" wx:for="{{tips}}" wx:key="index">• {{item}}</view>
  </view>

  <view class="card">
    <view class="action-item" bindtap="clearCache">清除本地缓存</view>
    <view class="action-item" bindtap="goToAbout">关于我们</view>
    <view class="action-item" bindtap="goBack">返回上一页</view>
  </view>
</view>
