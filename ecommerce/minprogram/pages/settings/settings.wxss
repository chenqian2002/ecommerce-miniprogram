/* pages/settings/settings.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  box-sizing: border-box;
}

.title {
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
  color: #0f172a;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.row {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.row:last-child {
  margin-bottom: 0;
}

.action-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  color: #0f172a;
  font-size: 28rpx;
}

.action-item:last-child {
  border-bottom: none;
}

.back-btn {
  width: 100%;
  margin-top: 8rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #0f172a;
  border: 1rpx solid #e2e8f0;
}
