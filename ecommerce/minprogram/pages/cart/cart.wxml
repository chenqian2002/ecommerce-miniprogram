<!--pages/cart/cart.wxml-->
<view class="cart-container">
  <view class="empty-state" wx:if="{{loading}}">
    <view class="empty-text">购物车加载中...</view>
  </view>

  <view class="empty-state" wx:elif="{{cart.length === 0}}">
    <view class="empty-text">购物车是空的</view>
    <view class="empty-tip">去商品页选购商品后再回来结算</view>
  </view>

  <view wx:else>
    <view class="cart-list">
      <view 
        wx:for="{{cart}}" 
        wx:key="id"
        class="cart-item"
      >
        <view class="item-name">{{item.name}}</view>
        <view class="item-price">¥{{item.price}}</view>
        <view class="item-qty">数量: {{item.quantity}}</view>
        <view class="qty-actions">
          <button class="qty-btn" bindtap="handleReduceQuantity" data-item-id="{{item.id}}">-</button>
          <button class="qty-btn" bindtap="handleIncreaseQuantity" data-item-id="{{item.id}}">+</button>
        </view>
        <button 
          class="item-remove"
          bindtap="handleRemoveItem"
          data-item-id="{{item.id}}"
        >
          删除
        </button>
      </view>
    </view>

    <view class="cart-footer">
      <view class="total-info">共 {{cart.length}} 件</view>
      <view class="total-price">合计：¥{{totalPrice}}</view>
      <button class="btn-checkout" bindtap="handleCheckout">
        立即结算
      </button>
    </view>
  </view>
</view>
