<!--pages/cart/cart.wxml-->
<view class="cart-container">
  <!-- 购物车为空 -->
  <view class="empty-state" wx:if="{{cart.length === 0}}">
    <view class="empty-text">购物车是空的</view>
  </view>

  <!-- 购物车内容 -->
  <view wx:else>
    <!-- 购物车列表 -->
    <view class="cart-list">
      <view 
        wx:for="{{cart}}" 
        wx:key="product_id"
        class="cart-item"
      >
        <view class="item-name">{{item.name}}</view>
        <view class="item-price">¥{{item.price}}</view>
        <view class="item-qty">数量: {{item.quantity}}</view>
        <button 
          class="item-remove"
          bindtap="handleRemoveItem"
          data-product-id="{{item.product_id}}"
        >
          删除
        </button>
      </view>
    </view>

    <!-- 结算栏 -->
    <view class="cart-footer">
      <view class="total-info">共 {{cart.length}} 件</view>
      <button class="btn-checkout" bindtap="handleCheckout">
        立即结算
      </button>
    </view>
  </view>
</view>
