/* pages/cart/cart.wxss */
.cart-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.empty-state {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 16px;
  color: #999;
  text-align: center;
}

.cart-list {
  flex: 1;
  overflow-y: auto;
  padding: 10px;
}

.cart-item {
  background: white;
  border-radius: 4px;
  padding: 12px;
  margin-bottom: 10px;
  border-bottom: 1px solid #eee;
}

.item-name {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 5px;
}

.item-price {
  font-size: 14px;
  color: #f60;
  margin-bottom: 5px;
}

.item-qty {
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
}

.item-remove {
  width: 60px;
  height: 28px;
  background-color: #f5f5f5;
  color: #333;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 12px;
  margin-top: 8px;
}

.cart-footer {
  padding: 12px;
  background-color: white;
  border-top: 1px solid #ddd;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total-info {
  font-size: 14px;
  color: #333;
}

.btn-checkout {
  height: 40px;
  background-color: #007acc;
  color: white;
  border: none;
  border-radius: 4px;
  font-size: 14px;
  font-weight: bold;
  width: 100px;
}
