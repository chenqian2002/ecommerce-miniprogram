/* pages/cart/cart.wxss */
.cart-container {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  box-sizing: border-box;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  font-size: 16px;
  color: #94a3b8;
  text-align: center;
  padding: 40rpx;
}

.empty-tip {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.cart-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 24rpx 140rpx;
}

.cart-item {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 26rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.item-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 10rpx;
}

.item-price {
  font-size: 30rpx;
  color: #ef4444;
  margin-bottom: 8rpx;
  font-weight: 700;
}

.item-qty {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 14rpx;
}

.qty-actions {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.qty-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  color: #0f172a;
  border: 1rpx solid #e2e8f0;
  font-size: 34rpx;
  line-height: 72rpx;
}

.item-remove {
  width: 120rpx;
  height: 56rpx;
  background: #f8fafc;
  color: #475569;
  border: 1rpx solid #e2e8f0;
  border-radius: 999rpx;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.cart-footer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  padding: 20rpx 24rpx;
  background: rgba(15, 23, 42, 0.94);
  backdrop-filter: blur(16px);
  border-radius: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.22);
}

.total-info {
  font-size: 26rpx;
  color: rgba(226, 232, 240, 0.75);
}

.total-price {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

.btn-checkout {
  height: 76rpx;
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
  color: #fff;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: bold;
  width: 180rpx;
  box-shadow: 0 12rpx 24rpx rgba(239, 68, 68, 0.25);
}


