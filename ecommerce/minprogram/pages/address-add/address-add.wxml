<!--pages/address-add/address-add.wxml-->
<view class="page">
  <view class="title">{{pageTitle}}</view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:else>
    <view class="form-item">
      <text class="label">收货人</text>
      <input class="input" placeholder="请输入收货人姓名" value="{{receiver_name}}" bindinput="handleInput" data-field="receiver_name" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" placeholder="请输入手机号" value="{{phone}}" bindinput="handleInput" data-field="phone" />
    </view>

    <view class="form-item">
      <text class="label">省份</text>
      <input class="input" placeholder="请输入省份" value="{{province}}" bindinput="handleInput" data-field="province" />
    </view>

    <view class="form-item">
      <text class="label">城市</text>
      <input class="input" placeholder="请输入城市" value="{{city}}" bindinput="handleInput" data-field="city" />
    </view>

    <view class="form-item">
      <text class="label">区县</text>
      <input class="input" placeholder="请输入区县" value="{{district}}" bindinput="handleInput" data-field="district" />
    </view>

    <view class="form-item">
      <text class="label">详细地址</text>
      <textarea class="textarea" placeholder="请输入街道、小区、门牌号等详细地址" value="{{detail}}" bindinput="handleInput" data-field="detail"></textarea>
    </view>

    <view class="form-item switch-row">
      <text class="label">设为默认地址</text>
      <switch checked="{{is_default}}" bindchange="handleDefaultChange" />
    </view>

    <button class="submit-btn" bindtap="handleSubmit" loading="{{submitting}}">{{submitText}}</button>
  </view>
</view>