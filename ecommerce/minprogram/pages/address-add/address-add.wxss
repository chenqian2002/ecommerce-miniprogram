/* pages/address-add/address-add.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  box-sizing: border-box;
}

.title {
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
  color: #0f172a;
}

.form-item,
.switch-row {
  background: rgba(255, 255, 255, 0.96);
  padding: 24rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 12rpx;
  color: #0f172a;
  font-weight: 700;
}

.switch-row .label {
  margin-bottom: 0;
}

.input,
.textarea {
  width: 100%;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: #f8fafc;
}

.textarea {
  min-height: 180rpx;
}

.submit-btn {
  margin-top: 30rpx;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
  border-radius: 999rpx;
  height: 92rpx;
  line-height: 92rpx;
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.24);
}