<!--pages/login/login.wxml-->
<view class="login-page">
  <view class="bg-circle circle-1"></view>
  <view class="bg-circle circle-2"></view>

  <view class="login-card">
    <view class="brand-badge">电商平台</view>
    <view class="login-title">欢迎回来</view>

    <!-- 商家登录模式 -->
    <block wx:if="{{loginMode === 'merchant'}}">
      <view class="login-subtitle">商家平台登录</view>

      <view class="form-group">
        <view class="input-label">手机号</view>
        <view class="input-wrap">
          <text class="input-icon">📱</text>
          <input
            class="input"
            type="text"
            placeholder="请输入手机号"
            value="{{phone}}"
            bindinput="handlePhoneChange"
          />
        </view>
      </view>

      <view class="form-group">
        <view class="input-label">密码</view>
        <view class="input-wrap">
          <text class="input-icon">🔒</text>
          <input
            class="input"
            type="password"
            placeholder="请输入密码"
            value="{{password}}"
            bindinput="handlePasswordChange"
          />
        </view>
      </view>

      <button class="primary-btn" bindtap="handleLogin" loading="{{loading}}" disabled="{{loading}}">
        {{loading ? '登录中...' : '商家登录'}}
      </button>

      <view class="switch-mode" bindtap="switchToUser">
        <text class="switch-text">👤 普通用户？点击微信登录</text>
      </view>
    </block>

    <!-- 用户登录模式（默认） -->
    <block wx:else>
      <view class="login-desc">使用微信账号一键登录，快速下单购物</view>

      <button class="wechat-btn" bindtap="handleWechatLogin" loading="{{loading}}" disabled="{{loading}}">
        <text class="wechat-btn-icon" wx:if="{{!loading}}">💬</text>
        <text>{{loading ? '登录中...' : '微信一键登录'}}</text>
      </button>

      <!-- 测试买家账密登录 -->
      <view class="test-divider">— 或者用测试账号登录 —</view>

      <view class="form-group">
        <view class="input-wrap">
          <text class="input-icon">📱</text>
          <input class="input" type="text" placeholder="买家测试手机号" value="{{phone}}" bindinput="handlePhoneChange" />
        </view>
      </view>
      <view class="form-group">
        <view class="input-wrap">
          <text class="input-icon">🔒</text>
          <input class="input" type="password" placeholder="密码：123456" value="{{password}}" bindinput="handlePasswordChange" />
        </view>
      </view>
      <button class="test-login-btn" bindtap="handleTestBuyerLogin" loading="{{loading}}" disabled="{{loading}}">
        {{loading ? '登录中...' : '买家测试登录'}}
      </button>

      <view class="switch-mode" bindtap="switchToMerchant">
        <text class="switch-text">🏬 商家登录</text>
      </view>
    </block>

    <view class="tips-card">
      <view class="tips-title">测试账号（上线前删除）</view>
      <view class="tips-item">商家：13859631156 / 123456</view>
      <view class="tips-item">买家：13800138001 / 123456</view>
      <view class="tips-item">买家：13800138002 / 123456</view>
    </view>
  </view>
</view>