/* pages/login/login.wxss */

.login-page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #0f172a 0%, #111827 40%, #f8fafc 100%);
  padding: 64rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(10px);
  opacity: 0.35;
}

.circle-1 {
  width: 260rpx;
  height: 260rpx;
  top: -80rpx;
  right: -70rpx;
  background: rgba(59, 130, 246, 0.8);
}

.circle-2 {
  width: 220rpx;
  height: 220rpx;
  left: -90rpx;
  top: 180rpx;
  background: rgba(236, 72, 153, 0.55);
}

.login-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 680rpx;
  margin: 120rpx auto 0;
  padding: 56rpx 40rpx 44rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 24rpx 80rpx rgba(15, 23, 42, 0.18);
  box-sizing: border-box;
}

.brand-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #1d4ed8;
  background: rgba(37, 99, 235, 0.12);
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 54rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.2;
}

.login-subtitle {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #2563eb;
  font-weight: 600;
}

.login-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.7;
}

.form-group {
  margin-top: 34rpx;
}

.input-label {
  font-size: 26rpx;
  color: #334155;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  box-sizing: border-box;
}

.input-icon {
  font-size: 30rpx;
  margin-right: 16rpx;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #0f172a;
}

.primary-btn,
.secondary-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 22rpx;
  line-height: 96rpx;
  margin-top: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.primary-btn {
  color: #fff;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.26);
}

.secondary-btn {
  color: #0f172a;
  background: #ffffff;
  border: 2rpx solid #dbe3ef;
}

.tips-card {
  margin-top: 34rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.tips-item {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.8;
}

.merchant-tip {
  color: #dc2626;
  font-weight: 600;
}

.announcement-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(15, 23, 42, 0.62);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.announcement-dialog {
  width: 100%;
  max-width: 620rpx;
  border-radius: 28rpx;
  background: #ffffff;
  padding: 36rpx 32rpx 28rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 72rpx rgba(15, 23, 42, 0.28);
}

.announcement-header {
  margin-bottom: 20rpx;
}

.announcement-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.announcement-content {
  max-height: 420rpx;
  overflow-y: auto;
  font-size: 28rpx;
  line-height: 1.8;
  color: #334155;
  white-space: pre-wrap;
  word-break: break-word;
}

.announcement-actions {
  margin-top: 32rpx;
}

.announcement-close-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

/* 微信登录按钮 */
.wechat-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 22rpx;
  line-height: 96rpx;
  margin-top: 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  color: #ffffff;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(7, 193, 96, 0.26);
}

.wechat-btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 切换登录模式 */
.switch-mode {
  margin-top: 30rpx;
  text-align: center;
}

.switch-text {
  font-size: 26rpx;
  color: #2563eb;
  font-weight: 500;
}

/* 测试买家登录区域 */
.test-divider {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin: 30rpx 0 10rpx;
}

.test-login-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 22rpx;
  line-height: 80rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  color: #fff;
  background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);
  box-shadow: 0 12rpx 24rpx rgba(245, 158, 11, 0.26);
}


