/* pages/login/login.wxss */

.login-page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #0f172a 0%, #111827 40%, #f8fafc 100%);
  padding: 64rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(10px);
  opacity: 0.35;
}

.circle-1 {
  width: 260rpx;
  height: 260rpx;
  top: -80rpx;
  right: -70rpx;
  background: rgba(59, 130, 246, 0.8);
}

.circle-2 {
  width: 220rpx;
  height: 220rpx;
  left: -90rpx;
  top: 180rpx;
  background: rgba(236, 72, 153, 0.55);
}

.login-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 680rpx;
  margin: 120rpx auto 0;
  padding: 56rpx 40rpx 44rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 24rpx 80rpx rgba(15, 23, 42, 0.18);
  box-sizing: border-box;
}

.brand-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #1d4ed8;
  background: rgba(37, 99, 235, 0.12);
  margin-bottom: 24rpx;
}

.login-title {
  font-size: 54rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.2;
}

.login-subtitle {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #2563eb;
  font-weight: 600;
}

.login-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.7;
}

.form-group {
  margin-top: 34rpx;
}

.input-label {
  font-size: 26rpx;
  color: #334155;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  box-sizing: border-box;
}

.input-icon {
  font-size: 30rpx;
  margin-right: 16rpx;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #0f172a;
}

.primary-btn,
.secondary-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 22rpx;
  line-height: 96rpx;
  margin-top: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.primary-btn {
  color: #fff;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  box-shadow: 0 16rpx 32rpx rgba(37, 99, 235, 0.26);
}

.secondary-btn {
  color: #0f172a;
  background: #ffffff;
  border: 2rpx solid #dbe3ef;
}

.tips-card {
  margin-top: 34rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.tips-item {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.8;
}

.merchant-tip {
  color: #dc2626;
  font-weight: 600;
}

