<!--pages/mine/mine.wxml-->
<view class="container">
  <view class="user-section">
    <view class="user-avatar">👤</view>
    <view class="user-info">
      <view class="user-name">{{userInfo.name || userInfo.nickname || '游客用户'}}</view>
      <view class="user-phone">{{userInfo.phone || '未登录'}}</view>
    </view>
    <view class="user-badge" wx:if="{{loading}}">更新中</view>
  </view>

  <view class="stats-section">
    <view class="stat-item" bindtap="goToOrders" data-status="pending">
      <view class="stat-icon">💳</view>
      <view class="stat-text">待付款</view>
      <view class="stat-count">{{stats.pending}}</view>
    </view>
    <view class="stat-item" bindtap="goToOrders" data-status="paid">
      <view class="stat-icon">📦</view>
      <view class="stat-text">待发货</view>
      <view class="stat-count">{{stats.paid}}</view>
    </view>
    <view class="stat-item" bindtap="goToOrders" data-status="shipped">
      <view class="stat-icon">🚚</view>
      <view class="stat-text">待收货</view>
      <view class="stat-count">{{stats.shipped}}</view>
    </view>
    <view class="stat-item" bindtap="goToOrders" data-status="completed">
      <view class="stat-icon">✅</view>
      <view class="stat-text">已完成</view>
      <view class="stat-count">{{stats.received}}</view>
    </view>
  </view>

  <view class="feature-card" wx:for="{{featureCards}}" wx:key="key" bindtap="handleFeature" data-key="{{item.key}}">
    <view class="feature-left">
      <view class="feature-icon">{{item.icon}}</view>
      <view>
        <view class="feature-title">{{item.title}}</view>
        <view class="feature-desc">{{item.desc}}</view>
      </view>
    </view>
    <view class="feature-arrow">›</view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToOrders">
      <view class="menu-left">
        <view class="menu-icon">📦</view>
        <view class="menu-text">我的订单</view>
      </view>
      <view class="menu-right">›</view>
    </view>

    <view class="menu-item" bindtap="goToAddress">
      <view class="menu-left">
        <view class="menu-icon">📍</view>
        <view class="menu-text">收货地址</view>
      </view>
      <view class="menu-right">›</view>
    </view>

    <view class="menu-item" bindtap="handleFavorites">
      <view class="menu-left">
        <view class="menu-icon">❤️</view>
        <view class="menu-text">我的收藏</view>
      </view>
      <view class="menu-right">›</view>
    </view>

    <view class="menu-item" bindtap="handleMerchant">
      <view class="menu-left">
        <view class="menu-icon">🏬</view>
        <view class="menu-text">商家平台</view>
      </view>
      <view class="menu-right">›</view>
    </view>

    <view class="menu-item" bindtap="handleSettings">
      <view class="menu-left">
        <view class="menu-icon">⚙️</view>
        <view class="menu-text">设置</view>
      </view>
      <view class="menu-right">›</view>
    </view>

    <view class="menu-item" bindtap="handleAbout">
      <view class="menu-left">
        <view class="menu-icon">ℹ️</view>
        <view class="menu-text">关于我们</view>
      </view>
      <view class="menu-right">›</view>
    </view>
  </view>

  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>

