/* pages/mine/mine.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 用户信息区 */
.user-section {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 20px 16px;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
  color: white;
  box-shadow: 0 4px 12px rgba(255, 107, 53, 0.2);
}

.user-avatar {
  width: 70px;
  height: 70px;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  flex-shrink: 0;
  border: 2px solid rgba(255, 255, 255, 0.4);
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 6px;
}

.user-phone {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.85);
}

/* 订单统计 */
.stats-section {
  display: flex;
  gap: 12px;
  background: white;
  margin: 16px 12px 0 12px;
  padding: 16px;
  border-radius: 8px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12px;
  border-radius: 6px;
  background: #fafafa;
  transition: all 0.2s;
}

.stat-item:active {
  background: #f0f0f0;
  transform: scale(0.95);
}

.stat-icon {
  font-size: 32px;
  margin-bottom: 6px;
}

.stat-text {
  font-size: 11px;
  color: #999;
  margin-bottom: 4px;
}

.stat-count {
  font-size: 18px;
  color: #ff6b35;
  font-weight: 700;
}

/* 功能菜单 */
.menu-section {
  background: white;
  margin: 16px 12px 0 12px;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid #f5f5f5;
  transition: background 0.2s;
}

.menu-item:active {
  background-color: #f9f9f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 14px;
  flex: 1;
}

.menu-icon {
  font-size: 22px;
  width: 28px;
  text-align: center;
}

.menu-text {
  font-size: 15px;
  color: #333;
  font-weight: 500;
}

.menu-right {
  font-size: 16px;
  color: #ddd;
}

/* 退出登录按钮 */
.logout-section {
  flex: 1;
  padding: 12px;
  display: flex;
  align-items: flex-end;
}

.logout-btn {
  width: 100%;
  height: 48px;
  background: linear-gradient(90deg, #ff6b35, #ff8c42);
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 600;
  box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
}

.logout-btn:active {
  background: linear-gradient(90deg, #e55a25, #e67c2f);
  box-shadow: 0 2px 8px rgba(255, 107, 53, 0.2);
}
