/* pages/mine/mine.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
}

.user-section {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 55%, #2563eb 100%);
  color: white;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.18);
}

.user-avatar {
  width: 70px;
  height: 70px;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  flex-shrink: 0;
  border: 2px solid rgba(255, 255, 255, 0.24);
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 6px;
}

.user-phone {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.82);
}

.user-badge {
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.14);
  font-size: 12px;
}

.stats-section {
  display: flex;
  gap: 12px;
  background: rgba(255, 255, 255, 0.96);
  margin: 16px 12px 0 12px;
  padding: 16px;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12px;
  border-radius: 18rpx;
  background: #f8fafc;
}

.stat-item:active {
  background: #eef2ff;
  transform: scale(0.97);
}

.stat-icon {
  font-size: 32px;
  margin-bottom: 6px;
}

.stat-text {
  font-size: 11px;
  color: #64748b;
  margin-bottom: 4px;
}

.stat-count {
  font-size: 18px;
  color: #2563eb;
  font-weight: 700;
}

.menu-section {
  background: rgba(255, 255, 255, 0.96);
  margin: 16px 12px 0 12px;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 16px;
  border-bottom: 1px solid #f8fafc;
}

.menu-item:active {
  background-color: #f8fafc;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 14px;
  flex: 1;
}

.menu-icon {
  font-size: 22px;
  width: 28px;
  text-align: center;
}

.menu-text {
  font-size: 15px;
  color: #0f172a;
  font-weight: 600;
}

.menu-right {
  font-size: 16px;
  color: #cbd5e1;
}


.feature-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 16px 12px 0 12px;
  padding: 18px 16px;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.feature-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

.feature-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.feature-title {
  font-size: 15px;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 4px;
}

.feature-desc {
  font-size: 12px;
  color: #64748b;
}

.feature-arrow {
  font-size: 20px;
  color: #cbd5e1;
}


.logout-btn {
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
  color: white;
  border: none;
  border-radius: 999rpx;
  font-size: 16px;
  font-weight: 700;
  box-shadow: 0 14rpx 28rpx rgba(239, 68, 68, 0.25);
}

.logout-btn:active {
  opacity: 0.92;
}

