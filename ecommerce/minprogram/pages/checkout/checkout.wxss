/* pages/checkout/checkout.wxss */
.checkout-page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  box-sizing: border-box;
}

.section-title {
  font-size: 38rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  color: #0f172a;
}

.section-desc,
.subscribe-tip {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 24rpx;
  line-height: 1.7;
}

.section-subtitle {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  color: #0f172a;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
}

.loading-text,
.empty-goods,
.empty-address {
  color: #64748b;
}

.empty-address {
  text-align: center;
  padding: 16rpx 0 8rpx;
}

.empty-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  color: #0f172a;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 20rpx;
}

.address-list {
  display: flex;
  flex-direction: column;
}

.address-item {
  border: 1rpx solid #e2e8f0;
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  background: #fff;
}

.address-item.active {
  border-color: #2563eb;
  background: #eff6ff;
}

.address-main {
  flex: 1;
}

.address-name {
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 10rpx;
}

.address-detail,
.goods-meta {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.goods-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.summary-card {
  margin-top: 0;
}

.summary-line {
  display: flex;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.submit-btn {
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
  color: #fff;
  border-radius: 999rpx;
  margin-top: 20rpx;
  height: 92rpx;
  line-height: 92rpx;
  box-shadow: 0 12rpx 24rpx rgba(239, 68, 68, 0.24);
}

.service-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(15, 23, 42, 0.62);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.service-dialog {
  width: 100%;
  border-radius: 30rpx;
  background: #fff;
  padding: 36rpx 30rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 72rpx rgba(15, 23, 42, 0.28);
}

.service-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #0f172a;
  text-align: center;
  margin-bottom: 12rpx;
}

.service-desc {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.7;
  text-align: center;
  margin-bottom: 24rpx;
}

.service-qr-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 22rpx;
}

.service-qr {
  width: 320rpx;
  height: 320rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.service-qr-placeholder {
  width: 320rpx;
  height: 320rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
  border: 2rpx dashed #cbd5e1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #64748b;
  text-align: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.qr-icon {
  font-size: 88rpx;
  line-height: 1;
  color: #2563eb;
  margin-bottom: 12rpx;
}

.qr-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.qr-tip {
  font-size: 22rpx;
  line-height: 1.5;
}

.wechat-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  margin-bottom: 24rpx;
}

.wechat-label {
  color: #64748b;
  font-size: 26rpx;
}

.wechat-value {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
}

.service-actions {
  display: flex;
  gap: 16rpx;
}

.copy-btn,
.order-btn,
.close-service-btn {
  border-radius: 999rpx;
  font-size: 26rpx;
}

.copy-btn {
  flex: 1;
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #fff;
}

.order-btn {
  flex: 1;
  background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
  color: #fff;
}

.close-service-btn {
  width: 100%;
  margin-top: 16rpx;
  background: #f8fafc;
  color: #475569;
  border: 1rpx solid #e2e8f0;
}
